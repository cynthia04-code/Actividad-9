import numpy as np
import matplotlib.pyplot as plt

x = np.linspace(-5, 5, 100)
y = np.linspace(-5, 5, 100)
X, Y = np.meshgrid(x, y)
Z = X**2 - 2 * Y**2

fig = plt.figure(figsize=(8, 6))
ax = fig.add_subplot(111, projection='3d')

superficie = ax.plot_surface(X, Y, Z, cmap='coolwarm', edgecolor='none', alpha=0.8)

ax.set_xlabel('Eje X')
ax.set_ylabel('Eje Y')
ax.set_zlabel('Eje Z')
fig.colorbar(superficie, shrink=0.5, aspect=5)

plt.show()
